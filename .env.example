# CCHT Platform - Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# SUPABASE CONFIGURATION (Required)
# ============================================
# Get these values from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Note: These are PUBLIC keys (safe to expose in frontend)
# The SECRET key should ONLY be used in server-side code

# ============================================
# PAYSTACK CONFIGURATION (Required for payments)
# ============================================
# Get these from: Paystack Dashboard → Settings → API Keys & Webhooks
# Use TEST keys first, then switch to LIVE keys when ready for production

# Public key - safe to use in browser
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxx

# Secret key - ONLY use on server side
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# CLOUDINARY CONFIGURATION (Required for uploads)
# ============================================
# Get these from: Cloudinary Dashboard → Settings → Access Keys

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# Upload preset options:
# - Use an unsigned preset for browser uploads, or
# - Use signed server-side uploads with the API secret
CLOUDINARY_UPLOAD_PRESET=your_unsigned_or_signed_preset

# Optional: force a single upload folder in your Cloudinary account
CLOUDINARY_FOLDER_PREFIX=ccht

# ============================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================
# Option 1: Gmail (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Option 2: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mail.yourdomain.com
# SMTP_PASS=your-mailgun-password

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment
NODE_ENV=development
# NODE_ENV=production (for deployment)

# Application URL (important for auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://your-domain.com (for production)

# ============================================
# SCHOOL INFORMATION (stored in database, but can set here)
# ============================================

SCHOOL_NAME=Covenant College of Health Technology
SCHOOL_LOCATION=Igbon, Oyo, Nigeria
SCHOOL_EMAIL=info@covenantcollegeofhealthtech.com.ng
SCHOOL_PHONE=+234 7066 3698 18
SCHOOL_PROVOST_EMAIL=provost@covenantcollegeofhealthtech.com.ng

# ============================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================

# Vercel Analytics (included with Vercel deployment)
# No setup needed - automatically collected

# Sentry (for error tracking) - optional
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# DATABASE CONFIGURATION (Auto-managed by Supabase)
# ============================================
# These are auto-configured by Supabase, shown for reference
# DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# TROUBLESHOOTING
# ============================================
# If you get auth errors:
# 1. Verify NEXT_PUBLIC_SUPABASE_URL is correct (no trailing slash)
# 2. Verify NEXT_PUBLIC_SUPABASE_ANON_KEY is correct
# 3. Check Supabase project is active

# If payment tests fail:
# 1. Use PAYSTACK_PUBLIC_KEY that starts with pk_test_
# 2. Use test card: 4111 1111 1111 1111, any CVV, future date
# 3. Verify webhook URL in Paystack settings

# If emails don't send:
# 1. Check SMTP credentials are correct
# 2. For Gmail: Use app-specific password, not regular password
# 3. Enable "Less secure app access" or use 2FA app password

# ============================================
# GETTING VALUES FOR EACH SERVICE
# ============================================

# SUPABASE SETUP:
# 1. Go to https://supabase.com
# 2. Click "New Project"
# 3. Fill in project details
# 4. Wait for project to be ready
# 5. Go to Settings → API
# 6. Copy Project URL → NEXT_PUBLIC_SUPABASE_URL
# 7. Copy Anon Public Key → NEXT_PUBLIC_SUPABASE_ANON_KEY

# PAYSTACK SETUP:
# 1. Go to https://paystack.com
# 2. Create account and verify email
# 3. Go to Dashboard → Settings → API Keys & Webhooks
# 4. Copy Live Public Key → PAYSTACK_PUBLIC_KEY (use pk_test_ for testing)
# 5. Copy Live Secret Key → PAYSTACK_SECRET_KEY (use sk_test_ for testing)
# 6. Add webhook URL: https://your-domain.com/api/v1/payments/paystack-webhook

# GMAIL SETUP (for email):
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Generate new app password for "Mail" and "Windows"
# 4. Copy the 16-character password → SMTP_PASS
# 5. Use your email → SMTP_USER

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before pushing to production:
# [ ] All values filled in (except optional ones)
# [ ] Database schema migrated in Supabase
# [ ] Test login works
# [ ] Test payment with Paystack test card
# [ ] Email sending verified (if configured)
# [ ] Dark mode toggle working
# [ ] Mobile responsive design verified
# [ ] SSL certificate activated (automatic on Vercel)
# [ ] Domain configured (if using custom domain)
# [ ] Paystack webhook configured
# [ ] Environment variables added to Vercel
# [ ] Build passes locally: pnpm build

# ============================================
# SECURITY NOTES
# ============================================
# 1. NEVER commit .env.local to GitHub
# 2. NEVER share SECRET keys in messages or docs
# 3. NEVER use database password in frontend code
# 4. Always use HTTPS in production
# 5. Rotate keys regularly
# 6. Use Vercel environment variables for sensitive data
# 7. Keep dependencies updated

